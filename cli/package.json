{
  "name": "create-qorechain-dapp",
  "version": "0.3.0",
  "description": "Scaffold a new QoreChain dApp from an official starter template.",
  "license": "Apache-2.0",
  "author": "QoreChain",
  "type": "module",
  "bin": {
    "create-qorechain-dapp": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "prepare:templates": "node scripts/copy-templates.mjs",
    "build": "node scripts/copy-templates.mjs && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qorechain/qorechain-sdk.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/qorechain/qorechain-sdk#readme",
  "bugs": {
    "url": "https://github.com/qorechain/qorechain-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
