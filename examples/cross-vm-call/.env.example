# Consensus RPC endpoint. Defaults to http://localhost:26657 when unset.
QORE_RPC_URL=http://localhost:26657
# REST endpoint. Defaults to http://localhost:1317 when unset.
QORE_REST_URL=http://localhost:1317
# Test mnemonic. Use a generated/test mnemonic ONLY — never a real secret.
QORE_MNEMONIC=
# Set to 1 to actually broadcast (needs a funded account). Otherwise dry-run.
QORE_BROADCAST=0
# Cross-VM targets.
QORE_EVM_CONTRACT=0xToken000000000000000000000000000000beef
QORE_SVM_PROGRAM=Prog11111111111111111111111111111111111111
QORE_EVM_RECIPIENT=0x1111111111111111111111111111111111111111
