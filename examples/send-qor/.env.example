# Consensus RPC endpoint. Defaults to http://localhost:26657 when unset.
QORE_RPC_URL=http://localhost:26657
# Cosmos REST (LCD) endpoint, used for the fee estimate. Defaults to :1317.
QORE_REST_URL=http://localhost:1317
# BIP-39 mnemonic of a FUNDED account. The public test mnemonic below is NOT
# funded on any real network — replace it to actually broadcast.
QORE_MNEMONIC=test test test test test test test test test test test junk
# Recipient bech32 address. Defaults to a sample qor1... address.
QORE_RECIPIENT=
# Display amount of QOR to send. Defaults to 1.5.
QORE_AMOUNT=1.5
