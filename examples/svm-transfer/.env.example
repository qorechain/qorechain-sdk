# SVM (Solana-compatible) JSON-RPC endpoint. Defaults to http://localhost:8899.
QORE_SVM_RPC_URL=http://localhost:8899
# BIP-39 mnemonic. The public test mnemonic below is used by default for the
# derived sender/recipient. Replace with a funded mnemonic to actually send.
QORE_MNEMONIC=test test test test test test test test test test test junk
# Optional explicit recipient (base58). Defaults to the index-1 derived account.
QORE_SVM_RECIPIENT=
