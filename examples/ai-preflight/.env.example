# EVM JSON-RPC endpoint. Defaults to http://localhost:8545 when unset.
QORE_EVM_RPC_URL=http://localhost:8545
# Sender (0x...) used for the anomaly check and gas estimate.
QORE_EVM_ADDRESS=0x0000000000000000000000000000000000000001
# Destination (0x...) of the sample transaction.
QORE_EVM_TO=0x0000000000000000000000000000000000000002
# Calldata to score. Defaults to a sample ERC-20 transfer(0x..,1) when unset.
QORE_EVM_DATA=
# Value to transfer, in wei. Defaults to 0.
QORE_EVM_VALUE=0
