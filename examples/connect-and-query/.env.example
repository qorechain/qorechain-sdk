# Cosmos REST (LCD) endpoint. Defaults to http://localhost:1317 when unset.
QORE_REST_URL=http://localhost:1317
# EVM JSON-RPC endpoint (the qor_* namespace is served here). Defaults to :8545.
QORE_EVM_RPC_URL=http://localhost:8545
# Address to query. Defaults to a sample qor1... address.
QORE_ADDRESS=
