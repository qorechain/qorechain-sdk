{
  "name": "@qorechain/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for building decentralized applications on the QoreChain network.",
  "license": "Apache-2.0",
  "author": "QoreChain",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qorechain/qorechain-sdk.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/qorechain/qorechain-sdk#readme",
  "bugs": {
    "url": "https://github.com/qorechain/qorechain-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
