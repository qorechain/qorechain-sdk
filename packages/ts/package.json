{
  "name": "@qorechain/sdk",
  "version": "0.5.0",
  "description": "Official TypeScript SDK for building decentralized applications on the QoreChain network.",
  "license": "Apache-2.0",
  "author": "QoreChain",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "codegen": "bash ../../scripts/codegen.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "docs:api": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qorechain/qorechain-sdk.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/qorechain/qorechain-sdk#readme",
  "bugs": {
    "url": "https://github.com/qorechain/qorechain-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@qorechain/evm": "workspace:*",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@qorechain/evm": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@cosmjs/amino": "^0.39.0",
    "@cosmjs/cosmwasm-stargate": "^0.39.0",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@cosmjs/tendermint-rpc": "^0.39.0",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "0.4.1",
    "@scure/base": "^1.2.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "bech32": "^2.0.0",
    "cosmjs-types": "^0.11.0",
    "micro-key-producer": "^0.9.0"
  },
  "devDependencies": {
    "@cosmjs/crypto": "^0.39.0",
    "@qorechain/evm": "workspace:*",
    "@types/node": "^22.7.5",
    "ts-proto": "^2.6.0",
    "tsup": "^8.3.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.6.3",
    "viem": "^2.0.0",
    "vitest": "^2.1.2"
  }
}
